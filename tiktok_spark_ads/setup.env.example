# TikTok API Credentials
# Copy this to .env and fill in your values
# NEVER commit the .env file to version control!

# From TikTok Developer Portal → Your App → App Details
TIKTOK_APP_ID=your_app_id_here
TIKTOK_APP_SECRET=your_app_secret_here

# Generated via OAuth flow (see SETUP.md)
TIKTOK_ACCESS_TOKEN=your_access_token_here

# From TikTok Ads Manager → Account Settings → Advertiser ID
TIKTOK_ADVERTISER_ID=your_advertiser_id_here

# Email Notifications (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Webhook Settings
WEBHOOK_PORT=5050
WEBHOOK_VERIFY_TOKEN=hashtaghamburg_verify_2024
